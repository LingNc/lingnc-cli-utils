detect_language() {
    if [[ "${MULTIUSER_LANG:-}" == "cn" ]] || [[ "${MULTIUSER_LANG:-}" == "zh" ]]; then
        CURRENT_LANG="cn"
    elif [[ "${LANG:-}" == *"CN"* ]] || [[ "${LANG:-}" == *"zh"* ]]; then
